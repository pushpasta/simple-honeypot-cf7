# EditorConfig is awesome: https://editorconfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[composer.json]
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx}]
indent_style = tab
indent_size = 4

[*.css]
indent_style = tab
indent_size = 4

[*.scss]
indent_style = tab
indent_size = 4

[*.html]
indent_style = tab
indent_size = 4

[*.xml]
indent_style = space
indent_size = 4

[*.svg]
indent_style = space
indent_size = 2

[{*.png,*.jpg,*.jpeg,*.gif,*.webp,*.ico}]
insert_final_newline = false
