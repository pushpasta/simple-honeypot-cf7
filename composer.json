{
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.13",
        "wp-coding-standards/wpcs": "^3.3",
        "wp-cli/wp-cli": "^2.12",
        "wp-cli/i18n-command": "^2.6"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "cs": "phpcs",
        "cbf": "phpcbf",
        "make-pot": "wp i18n make-pot . languages/simple-honeypot-cf7.pot --headers='{\"Report-Msgid-Bugs-To\":\"https://github.com/pushpasta/simple-honeypot-cf7/issues\"}'",
        "locales-yml": "php .github/scripts/generate-locale-options.php"
    }
}
